{
  "name": "r3ply-zola-theme",
  "version": "1.0.0",
  "description": "Comments for static sites",
  "scripts": {
    "build": "zola build $BUILD_OPTS && npx @tailwindcss/cli -i ./input.css -o ./public/style.css -m",
    "serve": "zola serve $SERVE_OPTS & npx @tailwindcss/cli  -i ./input.css -o ./public/style.css --watch && wait",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
