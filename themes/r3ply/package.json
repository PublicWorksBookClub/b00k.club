  "license": "MIT",
  "packageManager": "pnpm@10.6.2",
  "devDependencies": {
    "@r3ply/cli": "^0.0.1",
    "@tailwindcss/cli": "^4.3.1",
    "tailwindcss": "^4.3.1"
  }
}
