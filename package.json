{
  "name": "b00k.club",
  "version": "1.7.2",
  "private": true,
  "description": "The website for the Public Works Book Club: we only read works in the public domain",
  "scripts": {
    "initialize": "git submodule update --init --remote --recursive",
    "fmt": "npx prettier . --write",
    "build": "pnpm initialize && zola build $BUILD_OPTS && npx @tailwindcss/cli -i ./css/input.css -o ./public/style.css -m",
    "build:cf": "if [ \"$CF_PAGES_BRANCH\" = \"main\" ]; then pnpm build; else BUILD_OPTS=\"--base-url $CF_PAGES_URL\" pnpm build; fi",
    "serve": "zola serve --port 2665 $SERVE_OPTS & npx @tailwindcss/cli  -i ./css/input.css -o ./public/style.css --watch && wait",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PublicWorksBookClub/b00k.club"
  },
  "keywords": [
    "books",
    "book club",
    "public domain",
    "public works"
  ],
  "author": "Spencer Scorcelletti",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/PublicWorksBookClub/b00k.club/issues"
  },
  "homepage": "https://b00k.club/",
  "devDependencies": {
    "@r3ply/cli": "^0.0.2",
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/typography": "^0.5.9",
    "jsonld-cli": "^2.0.0",
    "prettier": "^3.6.2",
    "prettier-plugin-jinja-template": "^2.1.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "prettier-plugin-toml": "^2.0.6",
    "tailwindcss": "^4.2.2",
    "wrangler": "4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "volta": {
    "node": "22.23.1"
  }
}
